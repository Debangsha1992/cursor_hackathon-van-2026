//@version=5
// =============================================================================
// PaperPilot mean-reversion template
// Strategy: Bollinger band reversion with RSI confirmation. Fades extreme
// stretches against the band; exits at the band midline (target) or beyond
// the band (stop).
// =============================================================================
strategy("PaperPilot mean-reversion", overlay = true,
     default_qty_type = strategy.percent_of_equity, default_qty_value = 5)

// --- Inputs ----------------------------------------------------------------
bbLen     = input.int(20,  "BB length",       minval = 5)
bbMult    = input.float(2.0,"BB stddev mult", minval = 0.5, step = 0.1)
rsiLen    = input.int(14,  "RSI length",      minval = 2)
rsiHigh   = input.int(70,  "RSI overbought",  minval = 50, maxval = 90)
rsiLow    = input.int(30,  "RSI oversold",    minval = 10, maxval = 50)
stopOffset= input.float(0.5,"Stop offset (bands beyond)", minval = 0.0, step = 0.1)

// --- Signal ----------------------------------------------------------------
basis  = ta.sma(close, bbLen)
dev    = bbMult * ta.stdev(close, bbLen)
upper  = basis + dev
lower  = basis - dev
rsi    = ta.rsi(close, rsiLen)

longCondition  = close <= lower and rsi <= rsiLow
shortCondition = close >= upper and rsi >= rsiHigh

// --- Risk discipline -------------------------------------------------------
// Stop sits one band-width PAST the entry side; target is the basis midline.
// Reward/risk needs to be >= 1.5 to clear BOT_POOR_RISK_REWARD; the basis
// midline is usually far enough from a band tag that this holds.
var float stopLossPrice   = na
var float takeProfitPrice = na

if longCondition
    stopLossPrice   := lower - (dev * stopOffset)
    takeProfitPrice := basis
    strategy.entry("long", strategy.long,
         alert_message = "Close at lower BB with RSI oversold; mean-revert long")

if shortCondition
    stopLossPrice   := upper + (dev * stopOffset)
    takeProfitPrice := basis
    strategy.entry("short", strategy.short,
         alert_message = "Close at upper BB with RSI overbought; mean-revert short")

plot(stopLossPrice,   "stopLoss",   color = color.new(color.red, 100))   // {{plot_0}}
plot(takeProfitPrice, "takeProfit", color = color.new(color.green, 100)) // {{plot_1}}
